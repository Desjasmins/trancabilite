# Connexion PostgreSQL — copiez ce fichier en `.env` et renseignez vos URLs.

# DATABASE_URL : utilisée par l'APPLICATION au runtime.
#   - En local  : votre Postgres (Docker, etc.)
#   - Sur Vercel : pooler transaction Supabase (port 6543) — adapté au serverless.
DATABASE_URL="postgresql://user:password@localhost:5432/tracabilite?schema=public"

# DIRECT_URL : utilisée par la CLI Prisma (db push / migrate / seed) pour les
#   migrations. Connexion directe ou session pooler (port 5432). Facultatif :
#   si absente, la CLI retombe sur DATABASE_URL.
# DIRECT_URL="postgresql://postgres.xxxx:password@aws-1-us-east-1.pooler.supabase.com:5432/postgres"
